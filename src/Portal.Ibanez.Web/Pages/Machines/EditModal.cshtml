@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Portal.Ibanez.Localization
@using Portal.Ibanez.Web.Pages.Machines
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model EditModalModel
@inject IHtmlLocalizer<IbanezResource> L
@{
    Layout = null;
}

<form method="post" asp-page="/Machines/EditModal" >

    <abp-modal>

        <abp-modal-header title="Editar máquina"></abp-modal-header>

        <abp-modal-body>

            <abp-input asp-for="Id" />

            <abp-select asp-for="Machine.CustomerId"
                        asp-items="Model.Customers"
                        label="Cliente">
            </abp-select>

            <abp-select asp-for="Machine.MachineTypeId"
                        asp-items="Model.MachineTypes"
                        label="Tipo de máquina">
            </abp-select>

            <abp-input asp-for="Machine.OrderNumber" />

            <abp-input asp-for="Machine.CabinetNumber" />

            <abp-input asp-for="Machine.ManufacturingDate" />

            <abp-input asp-for="Machine.DeliveryDate" />

            <abp-input asp-for="Machine.Observations" />

        </abp-modal-body>

        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)">
        </abp-modal-footer>

    </abp-modal>

</form>