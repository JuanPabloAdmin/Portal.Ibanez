@page
@using Microsoft.AspNetCore.Authorization
@using Portal.Ibanez.Localization
@using Portal.Ibanez.Web.Pages.Customers
@using Microsoft.Extensions.Localization
@model IndexModel
@inject IStringLocalizer<IbanezResource> L

@section scripts {
    <script>
        $(function () {
            // Inicializamos los modales
            var createModal = new abp.ModalManager(abp.appPath + 'Customers/CreateModal');
            var editModal = new abp.ModalManager(abp.appPath + 'Customers/EditModal');

            // Abrir modal de crear
            $('#NewCustomerButton').click(function (e) {
                e.preventDefault();
                createModal.open();
            });

            // Abrir modal de editar
            $('.edit-customer-btn').click(function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                editModal.open({ id: id });
            });

            // CORRECCIÓN: Manejo del cierre del modal
            createModal.onResult(function () {
                // En lugar de reload(), hacemos una redirección dura para evitar artefactos del DOM
                window.location.href = '@Url.Page("/Customers/Index")';
            });

            editModal.onResult(function () {
                window.location.href = '@Url.Page("/Customers/Index")';
            });
        });
    </script>
}
<style>
    body {
        background-color: #f9fafb;
    }

    .btn-brand {
        background-color: #c71712;
        color: white;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-brand:hover {
            background-color: #a5130f;
            color: white;
            transform: translateY(-1px);
        }

    /* Diseño limpio para la tabla */
    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .custom-table th {
            background-color: #f3f4f6;
            color: #6b7280;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 1rem 1.5rem;
            font-weight: 600;
            border-bottom: 1px solid #e5e7eb;
        }

        .custom-table td {
            padding: 1rem 1.5rem;
            vertical-align: middle;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            font-size: 0.875rem;
            transition: background-color 0.15s;
        }

        .custom-table tbody tr:hover td {
            background-color: #f9fafb;
        }

    /* Iconos de acción */
    .action-icon {
        color: #9ca3af;
        transition: color 0.2s;
        padding: 0.25rem;
    }

        .action-icon:hover {
            color: #c71712;
        }

        .action-icon.view-machines:hover {
            color: #0d6efd;
        }
</style>

<div class="mb-4 d-flex justify-content-between align-items-center bg-white p-3 border rounded shadow-sm">
    <h2 class="h5 text-dark mb-0 d-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7Zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216ZM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
        </svg>
        <span class="text-muted fw-normal">Administración / </span>
        <span class="fw-bold">Clientes</span>
    </h2>
    <button id="NewCustomerButton" class="btn-brand d-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" /></svg>
        Nuevo cliente
    </button>
</div>

<div class="bg-white border rounded-3 shadow-sm overflow-hidden">

    <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light bg-opacity-50">
        <h3 class="h6 fw-bold text-secondary mb-0 text-uppercase tracking-wider" style="font-size: 0.8rem;">Directorio de Empresas</h3>
        <div class="input-group" style="width: 250px;">
            <span class="input-group-text bg-white border-end-0 text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" /></svg>
            </span>
            <input type="text" class="form-control border-start-0 ps-0 shadow-none" placeholder="Buscar cliente...">
        </div>
    </div>

    <div class="table-responsive">
        <table class="custom-table text-start">
            <thead>
                <tr>
                    <th>Nombre Comercial</th>
                    <th>Nombre Fiscal</th>
                    <th>CIF</th>
                    <th>Contacto</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Customers.Count > 0)
                {
                    foreach (var customer in Model.Customers)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@customer.CommercialName</td>
                            <td>@customer.FiscalName</td>

                            <td class="font-monospace text-muted">@customer.TaxId</td>

                            <td>
                                <div class="d-flex flex-column">
                                    <span>@customer.Email</span>
                                    <span class="text-muted small">@customer.Phone</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <a href="/Machines?customerId=@customer.Id" class="btn btn-link action-icon view-machines text-decoration-none" title="Ver Máquinas">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M10.478 1.647a.5.5 0 1 0-.956-.294l-4 13a.5.5 0 0 0 .956.294l4-13zM4.854 4.146a.5.5 0 0 1 0 .708L1.707 8l3.147 3.146a.5.5 0 0 1-.708.708l-3.5-3.5a.5.5 0 0 1 0-.708l3.5-3.5a.5.5 0 0 1 .708 0zm6.292 0a.5.5 0 0 0 0 .708L14.293 8l-3.147 3.146a.5.5 0 0 0 .708.708l3.5-3.5a.5.5 0 0 0 0-.708l-3.5-3.5a.5.5 0 0 0-.708 0z" /></svg>
                                </a>
                                <button type="button" class="btn btn-link action-icon edit-customer-btn text-decoration-none" data-id="@customer.Id" title="Editar">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" /></svg>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            No se encontraron clientes registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>