@page "{id:guid}"
@using Portal.Ibanez.Web.Pages.Machines
@model DetailModel
@{
    ViewBag.Title = "Gestión Técnica de Máquina";

    var customerName = string.IsNullOrWhiteSpace(Model.Machine.CustomerCommercialName) ? "Cliente" : Model.Machine.CustomerCommercialName;
    var machineName = string.IsNullOrWhiteSpace(Model.Machine.MachineTypeName) ? "Máquina" : Model.Machine.MachineTypeName;
}

@section scripts {
    <script>
        $(function () {
            // Inicialización de gestores de modales de ABP
            var editMachineModal = new abp.ModalManager(abp.appPath + 'Machines/EditModal');
            var createDocModal = new abp.ModalManager(abp.appPath + 'MachineDocuments/CreateModal');
            var editDocModal = new abp.ModalManager(abp.appPath + 'MachineDocuments/EditModal');
            var createQrModal = new abp.ModalManager(abp.appPath + 'QrCodes/CreateModal');
            var editQrModal = new abp.ModalManager(abp.appPath + 'QrCodes/EditModal');

            $('#EditMachineButton').click(function () { editMachineModal.open({ id: '@Model.Id' }); });
            $('#NewDocumentButton').click(function () { createDocModal.open({ machineId: '@Model.Id' }); });
            $('#NewQrButton').click(function () { createQrModal.open({ machineId: '@Model.Id' }); });

            $('.edit-doc-btn').click(function () { editDocModal.open({ id: $(this).data('id') }); });
            $('.edit-qr-btn').click(function () { editQrModal.open({ id: $(this).data('id') }); });

            // Recarga tras operaciones en modales
            const reload = () => window.location.reload();
            editMachineModal.onResult(reload);
            createDocModal.onResult(reload);
            editDocModal.onResult(reload);
            createQrModal.onResult(reload);
            editQrModal.onResult(reload);

            // Gestión de estado visual (Tabs y Acordeones) tras redirección
            var hash = window.location.hash;
            if (hash && hash.startsWith("#collapse-")) {
                // Activar pestaña de vinculación
                var tabTrigger = document.querySelector('.nav-tabs-custom a[href="#tab-links"]');
                if (tabTrigger) { new bootstrap.Tab(tabTrigger).show(); }

                // Expandir acordeón específico
                var accordionBody = document.querySelector(hash);
                if (accordionBody) {
                    var collapseInstance = new bootstrap.Collapse(accordionBody, { toggle: false });
                    collapseInstance.show();
                    setTimeout(() => { accordionBody.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 200);
                }
            }
        });
    </script>
}

<style>
    body {
        background-color: #f8fafc;
    }

    .sidebar-info {
        background: white;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
    }

    .nav-tabs-custom .nav-link {
        border: none;
        color: #64748b;
        font-weight: 600;
        padding: 1rem 1.25rem;
        border-bottom: 3px solid transparent;
    }

        .nav-tabs-custom .nav-link.active {
            color: #c71712;
            border-bottom-color: #c71712;
            background: #fff;
        }

    .item-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        transition: all 0.2s ease;
        height: 100%;
    }

        .item-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            border-color: #e8a09e;
        }

    .accordion-button:not(.collapsed) {
        background-color: #fff1f2;
        color: #c71712;
        font-weight: 700;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4 px-2">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item"><a href="/Customers" class="text-decoration-none text-muted">Clientes</a></li>
            <li class="breadcrumb-item"><a href="/Machines?customerId=@Model.Machine.CustomerId" class="text-decoration-none text-muted">Máquinas de @customerName</a></li>
            <li class="breadcrumb-item active fw-bold text-dark">Detalle de Máquina</li>
        </ol>
    </nav>
    <div class="badge bg-white text-dark border p-2 font-monospace shadow-sm">REF: @Model.Machine.OrderNumber</div>
</div>

<div class="row g-4">
    <div class="col-lg-3">
        <div class="sidebar-info p-4 shadow-sm h-100">
            <div class="d-flex align-items-center gap-2 mb-3 text-success fw-bold small text-uppercase">
                <span class="rounded-circle bg-success" style="width: 8px; height: 8px;"></span> Operativa
            </div>
            <h4 class="fw-bold mb-4 text-dark">@machineName</h4>
            <div class="mb-4">
                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Identificación</label>
                <div class="bg-light p-2 rounded border font-monospace text-dark mb-3">
                    @Model.Machine.OrderNumber / @Model.Machine.CabinetNumber
                </div>
                <div class="row g-2">
                    <div class="col-6">
                        <label class="text-muted small fw-bold text-uppercase d-block">Fabricación</label>
                        <span class="text-dark small">@(Model.Machine.ManufacturingDate?.ToShortDateString() ?? "-")</span>
                    </div>
                    <div class="col-6 text-end">
                        <label class="text-muted small fw-bold text-uppercase d-block">Entrega</label>
                        <span class="text-dark small">@(Model.Machine.DeliveryDate?.ToShortDateString() ?? "-")</span>
                    </div>
                </div>
            </div>
            <button id="EditMachineButton" class="btn btn-outline-secondary w-100 btn-sm fw-bold mt-2">Editar Ficha</button>
        </div>
    </div>

    <div class="col-lg-9">
        <div class="bg-white rounded-4 shadow-sm border overflow-hidden">
            <ul class="nav nav-tabs nav-tabs-custom border-bottom bg-light bg-opacity-50" role="tablist">
                <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-docs">Documentos</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-qr">Códigos QR</a></li>
                <li class="nav-item"><a class="nav-link text-primary" data-bs-toggle="tab" href="#tab-links"><i class="fa fa-link me-1"></i> Vincular</a></li>
            </ul>

            <div class="tab-content p-4">
                <div class="tab-pane fade show active" id="tab-docs">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Archivos Asociados</h5>
                        <button id="NewDocumentButton" class="btn btn-sm px-3 text-white" style="background: #c71712;">Nuevo PDF</button>
                    </div>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                        @foreach (var doc in Model.Documents)
                        {
                            <div class="col">
                                <div class="item-card p-3 d-flex flex-column">
                                    <div class="d-flex align-items-start gap-3 mb-3">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#c71712" viewBox="0 0 16 16"><path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z" /></svg>
                                        <div class="overflow-hidden">
                                            <h6 class="fw-bold mb-1 text-truncate text-dark">@doc.Title</h6>
                                            <div class="text-muted extra-small text-truncate" style="font-size: 0.7rem;">@doc.FileName</div>
                                        </div>
                                    </div>
                                    <div class="mt-auto btn-group w-100 shadow-sm">
                                        <button class="btn btn-light btn-sm fw-bold border-end edit-doc-btn" data-id="@doc.Id">Editar</button>
                                        <a href="/MachineDocuments/Download/@doc.Id" class="btn btn-light btn-sm fw-bold text-danger">Bajar</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-qr">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0">Códigos QR Generados</h5>
                        <button id="NewQrButton" class="btn btn-dark btn-sm px-3">Nuevo QR</button>
                    </div>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                        @foreach (var qr in Model.QrCodes)
                        {
                            <div class="col">
                                <div class="item-card p-3 d-flex align-items-center gap-3">
                                    <div class="bg-light p-2 rounded border">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#334155" viewBox="0 0 16 16"><path d="M2 2h2v2H2V2Z" /><path d="M6 0v6H0V0h6ZM5 1H1v4h4V1ZM4 12H2v2h2v-2Z" /><path d="M6 10v6H0v-6h6Zm-5 1v4h4v-4H1Zm11-9h2v2h-2V2Z" /><path d="M10 0v6h6V0h-6Zm5 1v4h-4V1h4ZM8 1V0h1v2H8v2H7V1h1Zm0 5V4h1v2H8ZM6 8V7h1V6h1v2h1V7h5v1h-4v1H7V8H6Zm0 0v1H2V8H1v1H0V7h3v1h3Zm10 1h-1V7h1v2Zm-1 0h-1v2h2v-1h-1V9Zm-4 0h2v1h-1v1h-1V9Zm2 3v-1h-1v1h1Zm-1 0v1h2v-1h-2Zm-4 0h1v2h-1v-2Zm1 0h1v-1h-1v1Zm0 2h1v1h-1v-1Zm-1 0v-1h-1v2h2v-1Zm-1 0H8v-1h1v1Zm-2 0H6v1h1v-1Zm-1 0v-1H4v1h1Zm0 1V9h-1v2h1Zm-1 0v1H2v-1h1Zm0 1v1H1v-1h1Zm0 1H1v-1H0v2h2v-1Zm2 0v-1H3v1h1Zm0-1v1h1v-1H4Zm1-1V9h1v1H5Zm1 0v1h1v-1H6Zm1-1H6v1h1v-1Zm0 1v1h-1v-1h1Zm0 1v1h1v-1H7Zm1 1H7v1h2v-1H8Zm1-1h1v1h-1v-1Zm0-1h-1v1h1v-1Zm0-1v-1h1v1h-1Zm1 0v1h1v-1h-1Zm1 0v-1h1v1h-1Zm1 0v1h1v-1h-1Zm1 0v-1h1v1h-1Zm0 1h1v1h-1v-1Zm-1 0v1h-1v-1h1Zm-1 0h1v-1h-1v1Zm0 1v1h1v-1h-1Zm-1 0h1v-1h-1v1Zm0 1h1v1h-1v-1Zm-1 0v1h-1v-1h1Z" /></svg>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <h6 class="fw-bold mb-0 text-dark text-truncate">@qr.Name</h6>
                                        <small class="font-monospace text-muted">@qr.Code</small>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a href="/q/@qr.Code" target="_blank" class="btn btn-outline-dark btn-sm p-1" title="Previsualizar">
                                            <i class="fa fa-eye"></i>
                                        </a>

                                        <a asp-page-handler="DownloadQr" asp-route-id="@Model.Id" asp-route-qrId="@qr.Id"
                                           class="btn btn-outline-primary btn-sm p-1" title="Descargar para Cliente">
                                            <i class="fa fa-download"></i>
                                        </a>

                                        <button class="btn btn-outline-secondary btn-sm p-1 edit-qr-btn" data-id="@qr.Id" title="Editar">
                                            <i class="fa fa-edit"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-links">
                    <div class="mb-4">
                        <h5 class="fw-bold mb-1">Configuración de Accesos</h5>
                        <p class="text-muted small">Define qué documentos son accesibles desde cada código QR.</p>
                    </div>
                    <div class="accordion shadow-sm border rounded" id="qrLinkAccordion">
                        @foreach (var qr in Model.QrCodes)
                        {
                            var linked = Model.QrLinkedDocuments[qr.Id];
                            <div class="accordion-item border-0 border-bottom last-child-border-0">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@qr.Id">
                                        <span class="fw-bold me-2">QR: @qr.Name</span>
                                        <span class="badge bg-primary rounded-pill fw-normal" style="font-size: 0.7rem;">@linked.Count documentos</span>
                                    </button>
                                </h2>
                                <div id="collapse-@qr.Id" class="accordion-collapse collapse" data-bs-parent="#qrLinkAccordion">
                                    <div class="accordion-body bg-light p-0">
                                        <table class="table table-sm table-hover bg-white mb-0 text-start align-middle">
                                            <thead class="table-light"><tr><th class="ps-4 py-2">Documento</th><th class="text-center py-2">Acción</th></tr></thead>
                                            <tbody>
                                                @foreach (var doc in Model.Documents)
                                                {
                                                    var link = linked.FirstOrDefault(x => x.MachineDocumentId == doc.Id);
                                                    <tr>
                                                        <td class="ps-4 py-3"><div class="fw-bold small">@doc.Title</div><div class="extra-small text-muted font-monospace">@doc.FileName</div></td>
                                                        <td class="text-center pe-4">
                                                            @if (link != null)
                                                            {
                                                                <form method="post" asp-page-handler="RemoveLink" asp-route-id="@Model.Id">
                                                                    <input type="hidden" name="qrId" value="@qr.Id" />
                                                                    <input type="hidden" name="linkId" value="@link.Id" />
                                                                    <input type="hidden" name="machineId" value="@Model.Id" />
                                                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3 fw-bold" style="font-size: 0.7rem;">Quitar</button>
                                                                </form>
                                                            }
                                                            else
                                                            {
                                                                <form method="post" asp-page-handler="AddLink" asp-route-id="@Model.Id">
                                                                    <input type="hidden" name="qrId" value="@qr.Id" />
                                                                    <input type="hidden" name="docId" value="@doc.Id" />
                                                                    <input type="hidden" name="machineId" value="@Model.Id" />
                                                                    <button type="submit" class="btn btn-sm btn-outline-success px-3 fw-bold" style="font-size: 0.7rem;">Vincular</button>
                                                                </form>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>