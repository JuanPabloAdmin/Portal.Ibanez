@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Portal.Ibanez.Localization
@using Portal.Ibanez.Web.Pages.Customers
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model CreateModalModel
@inject IHtmlLocalizer<IbanezResource> L

<abp-dynamic-form abp-model="Customer" asp-page="/Customers/CreateModal">
    <abp-modal>
        <abp-modal-header title="Nuevo cliente" class="bg-light border-bottom"></abp-modal-header>

        <abp-modal-body class="pt-4">
            <abp-form-content />
        </abp-modal-body>

        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)">
        </abp-modal-footer>
    </abp-modal>
</abp-dynamic-form>