                                <div class="lpx-brand-logo lpx-login-logo mb-3 w-100" style="background-position: left"></div>
                                <h4 class="lh-base d-none d-md-block">
                                </h4>
                            </div>

                            <div class="copyright text-start mt-3 text-black">
                                <!-- Footer -->
