@page
@using Microsoft.AspNetCore.Authorization
@using Portal.Ibanez.Localization
@using Portal.Ibanez.Web.Pages.Customers
@using Microsoft.Extensions.Localization
@model IndexModel
@inject IStringLocalizer<IbanezResource> L

@section scripts {
    <script>
        $(function () {
            var createModal = new abp.ModalManager(abp.appPath + 'Customers/CreateModal');
            var editModal = new abp.ModalManager(abp.appPath + 'Customers/EditModal');

            $('#NewCustomerButton').click(function (e) {
                e.preventDefault();
                createModal.open();
            });

            $('.edit-customer-btn').click(function (e) {
                e.preventDefault();
                var id = $(this).data('id');
                editModal.open({ id: id });
            });

            createModal.onResult(function () { window.location.href = '@Url.Page("/Customers/Index")'; });
            editModal.onResult(function () { window.location.href = '@Url.Page("/Customers/Index")'; });

            // Buscador en tiempo real
            $("#customerSearchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $(".customer-card-wrapper").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}

<style>
    body {
        background-color: #f4f7f9;
        font-family: 'Inter', system-ui, sans-serif;
    }

    .btn-brand {
        background-color: #c71712;
        color: white;
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-brand:hover {
            background-color: #a5130f;
            color: white;
            transform: translateY(-1px);
        }

    /* Tarjeta de Cliente Moderna */
    .customer-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        transition: all 0.25s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

        .customer-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 20px -8px rgba(0,0,0,0.1);
            border-color: #d1d5db;
        }

    .customer-header {
        padding: 1.5rem;
        background: linear-gradient(to bottom, #ffffff, #f9fafb);
        border-bottom: 1px solid #f3f4f6;
    }

    .company-avatar {
        width: 48px;
        height: 48px;
        background-color: #f3f4f6;
        color: #374151;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-weight: 700;
        font-size: 1.25rem;
        border: 1px solid #e5e7eb;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 0.75rem;
        font-size: 0.85rem;
    }

    .info-label {
        color: #9ca3af;
        text-transform: uppercase;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        width: 60px;
    }

    .card-footer-actions {
        padding: 1rem;
        background-color: #f9fafb;
        border-top: 1px solid #f3f4f6;
        display: flex;
        gap: 8px;
    }

    .btn-action-main {
        background-color: #374151;
        color: white;
        font-weight: 600;
        font-size: 0.8rem;
        flex-grow: 1;
        border-radius: 8px;
    }

        .btn-action-main:hover {
            background-color: #111827;
            color: white;
        }

    /* Buscador */
    .search-wrapper {
        position: relative;
        width: 300px;
    }

        .search-wrapper svg {
            position: absolute;
            left: 12px;
            top: 11px;
            color: #9ca3af;
        }

        .search-wrapper input {
            padding-left: 2.5rem;
            border-radius: 10px;
            border-color: #e5e7eb;
        }
</style>

<div class="mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center bg-white p-4 border rounded-4 shadow-sm gap-3">
    <h2 class="h4 text-dark mb-0 d-flex align-items-center gap-2">
        <div class="p-2 bg-light rounded-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#6b7280" viewBox="0 0 16 16">
                <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7Zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216ZM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
            </svg>
        </div>
        <div>
            <span class="text-muted fw-normal fs-6 d-block" style="line-height: 1;">Administración /</span>
            <span class="fw-bold">Clientes</span>
        </div>
    </h2>

    <div class="d-flex gap-3">
        <div class="search-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" /></svg>
            <input type="text" id="customerSearchInput" class="form-control" placeholder="Buscar por nombre, CIF o email...">
        </div>
        <button id="NewCustomerButton" class="btn-brand d-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" /></svg>
            Nuevo cliente
        </button>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    @if (Model.Customers.Count > 0)
    {
        foreach (var customer in Model.Customers)
        {
            var initial = !string.IsNullOrEmpty(customer.CommercialName) ? customer.CommercialName.Substring(0, 1).ToUpper() : "?";

            <div class="col customer-card-wrapper">
                <div class="customer-card shadow-sm">
                    <div class="customer-header d-flex align-items-center gap-3">
                        <div class="company-avatar">@initial</div>
                        <div class="overflow-hidden">
                            <h3 class="h6 fw-bold text-dark mb-0 text-truncate" title="@customer.CommercialName">@customer.CommercialName</h3>
                            <span class="text-muted small">ID: @customer.TaxId</span>
                        </div>
                    </div>

                    <div class="p-4 flex-grow-1">
                        <div class="info-row">
                            <span class="info-label">Fiscal</span>
                            <span class="text-dark fw-medium text-truncate">@customer.FiscalName</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Email</span>
                            <a href="mailto:@customer.Email" class="text-decoration-none text-primary text-truncate">@customer.Email</a>
                        </div>
                        <div class="info-row mb-0">
                            <span class="info-label">Teléfono</span>
                            <span class="text-secondary">@customer.Phone</span>
                        </div>
                    </div>

                    <div class="card-footer-actions">
                        <a href="/Machines?customerId=@customer.Id" class="btn btn-action-main d-flex align-items-center justify-content-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM9 2.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z" /></svg>
                            Ver Máquinas
                        </a>
                        <button type="button" class="btn btn-light border edit-customer-btn px-3" data-id="@customer.Id" title="Editar Cliente">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#6b7280" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="bg-white p-5 rounded-4 border text-muted">
                <p class="mb-0">No hay clientes registrados en el sistema.</p>
            </div>
        </div>
    }
</div>