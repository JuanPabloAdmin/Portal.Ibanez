                                </span>
                                <!-- Footer -->
                            </div>
                        </div>
                    </div>

                    <div class="col-11 mx-auto col-md-7">
                        <div class="card m-0">
                            <div class="card-body d-md-flex flex-column justify-content-md-center login-h-100 position-relative p-0">
                                <!-- Card -->
                                <div class="card mx-auto shadow-none border-0 rounded-3 w-100" style="max-width: 30rem">
                                    <div class="card-body p-4">
                                        <img src="/assets/images/logo.png" style="width: 20%; margin-bottom: 2vh;" alt="">
                                        <div class="align-items-start d-flex justify-content-between mb-2">
                                            <!-- Title -->
                                            <h2 class="lpx-main-title lpx-login-title m-0 me-auto">Iniciar Sesión</h2>
                                        </div>

                                        <form method="post" novalidate onsubmit="return validateForm()">
                                            @if (!ViewData.ModelState.IsValid)
                                            {
                                                <div class="alert alert-danger mb-3">
                                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                                    {
                                                        <div>@error.ErrorMessage</div>
                                                    }
                                                </div>
                                            }

                                            <div class="mb-3" style="color:white">
                                                <label for="LoginInput_UserNameOrEmailAddress" class="form-label">@L["UserNameOrEmailAddress"]</label>
                                                <input type="text" class="form-control" id="LoginInput_UserNameOrEmailAddress" name="UserNameOrEmailAddress" required />
                                                <div class="invalid-feedback">El nombre de usuario o correo electrónico es obligatorio.</div>
                                            </div>

                                            <div class="mb-3 form-group position-relative mt-3">
                                                <label for="LoginInput_Password" style="color:white;" class="form-label">@L["Password"]</label>
                                                <div class="input-group">
                                                    <input type="password" class="form-control" id="LoginInput_Password" name="Password" required />
                                                    <span class="input-group-text" id="togglePassword" style="cursor: pointer;">
                                                        <i class="fa-regular fa-eye"></i>
                                                    </span>
                                                </div>
                                                <div class="invalid-feedback">La contraseña es obligatoria.</div>

                                                <div id="passwordError" class="invalid-feedback">
