@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Portal.Ibanez.Localization
@using Portal.Ibanez.Web.Pages.MachineDocuments
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model EditModalModel
@inject IHtmlLocalizer<IbanezResource> L
@{
    Layout = null;
}

<form method="post" asp-page="/MachineDocuments/EditModal">

    <abp-modal>

        <abp-modal-header title="Editar documento"></abp-modal-header>

        <abp-modal-body>

            <abp-input asp-for="Id" />

            <abp-input asp-for="Document.MachineId" />

            <abp-input asp-for="Document.Title" />

            <abp-input asp-for="Document.FileName" />

            <abp-input asp-for="Document.IsActive" />

        </abp-modal-body>

        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)">
        </abp-modal-footer>

    </abp-modal>

</form>