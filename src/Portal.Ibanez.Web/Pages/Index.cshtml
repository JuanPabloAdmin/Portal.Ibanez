@page
@model Portal.Ibanez.Web.Pages.IndexModel

<script>
    $(function () {
    // Escuchar el evento oficial de Bootstrap cuando un modal termina de ocultarse
    $(document).on('hidden.bs.modal', '.modal', function () {
        var $modal = $(this);
        
        // 1. Ocultar por fuerza bruta
        $modal.hide().css('display', 'none');
        
        // 2. Si el formulario inyectado se quedó vacío o colgado, lo ocultamos
        if ($modal.closest('form').length > 0) {
            $modal.closest('form').css({
                'height': '0',
                'margin': '0',
                'display': 'none'
            });
        }

        // 3. Si ya no queda NINGÚN otro modal abierto en la pantalla...
        if ($('.modal.show').length === 0) {
            // Liberamos el scroll de la página
            $('body').removeClass('modal-open').css({
                'overflow': '',
                'padding-right': ''
            });
            
            // Destruimos cualquier fondo oscuro fantasma que haya quedado
            $('.modal-backdrop').remove();
        }
    });
});
</script>